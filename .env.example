# ─────────────────────────────────────────────────────────────────────────────
# SensorModel v1.0 — Environment Variables
# Corverxis Technologies
#
# Copy this file to .env.local for local development.
# Set these as environment variables in your Render.com service dashboard.
# NEVER commit .env or .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
NEXTAUTH_URL=https://your-app.onrender.com
NEXTAUTH_SECRET=                        # openssl rand -base64 32

# ── Database (PostgreSQL on Render) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/sensormodel?sslmode=require

# ── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OAuth2 Providers ─────────────────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Entra ID (Azure AD) — https://portal.azure.com
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=                     # "common" for multi-tenant

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                          # debug | info | warn | error

# ── Security ─────────────────────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-app.onrender.com

# ── Optional: Redis for rate limiting (multi-instance) ───────────────────────
# REDIS_URL=redis://...

# ── Optional: Email (for auth verification) ──────────────────────────────────
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@corverxis.com

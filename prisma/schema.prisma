generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(PENDING)
  orgId         String?
  org           Org?      @relation(fields: [orgId], references: [id])

  // Approval
  approved        Boolean   @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedReason  String?
  registeredAt    DateTime  @default(now())

  // Auth
  accounts   Account[]
  sessions   Session[]
  apiKeys    ApiKey[]

  // Activity
  sensorSessions SensorSession[]
  auditLogs      AuditLog[]
  alerts         Alert[]

  // Security
  consentGivenAt   DateTime?
  dataRegion       String    @default("us-east-1")
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([orgId])
  @@index([approved])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ENGINEER
  VIEWER
  PENDING
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Org {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  plan       OrgPlan @default(STARTER)
  dataRegion String  @default("us-east-1")

  users      User[]
  assets     Asset[]
  apiKeys    ApiKey[]
  auditLogs  AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orgs")
}

enum OrgPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  userId     String
  orgId      String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Org?      @relation(fields: [orgId], references: [id])
  scopes     String[]  @default(["predict:read"])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  description String?
  orgId       String
  org         Org      @relation(fields: [orgId], references: [id])
  vertical    String
  location    String?
  tags        String[] @default([])

  sensors  Sensor[]
  sessions SensorSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("assets")
}

model Sensor {
  id          String @id @default(cuid())
  name        String
  type        String
  unit        String
  assetId     String
  asset       Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  config      Json   @default("{}")
  thresholds  Json   @default("{}")
  mlAlgorithm String @default("ensemble")

  readings    SensorReading[]
  predictions Prediction[]
  alerts      Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@map("sensors")
}

model SensorReading {
  id        String   @id @default(cuid())
  sensorId  String
  sensor    Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  value     Float
  quality   Float    @default(1.0)
  timestamp DateTime @default(now())

  @@index([sensorId, timestamp])
  @@map("sensor_readings")
}

model Prediction {
  id         String   @id @default(cuid())
  sensorId   String
  sensor     Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  algorithm  String
  predicted  Float
  confidence Float
  rulHours   Float?
  features   Json     @default("{}")
  timestamp  DateTime @default(now())

  @@index([sensorId, timestamp])
  @@map("predictions")
}

model SensorSession {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id])
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  config    Json      @default("{}")
  ipAddress String?

  @@index([userId])
  @@index([assetId])
  @@map("sensor_sessions")
}

model Alert {
  id         String     @id @default(cuid())
  sensorId   String
  sensor     Sensor     @relation(fields: [sensorId], references: [id])
  userId     String?
  user       User?      @relation(fields: [userId], references: [id])
  severity   AlertLevel
  type       String
  message    String
  value      Float?
  threshold  Float?
  resolved   Boolean    @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime   @default(now())

  @@index([sensorId])
  @@index([resolved])
  @@map("alerts")
}

enum AlertLevel {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  orgId      String?
  org        Org?     @relation(fields: [orgId], references: [id])
  action     String
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  outcome    String   @default("success")
  metadata   Json     @default("{}")
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([timestamp])
  @@map("audit_logs")
}

model DataRetentionPolicy {
  id               String    @id @default(cuid())
  dataType         String    @unique
  retentionDays    Int
  archiveAfterDays Int?
  deleteAfterDays  Int?
  lastRunAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("data_retention_policies")
}

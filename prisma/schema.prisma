// SensorModel - Prisma Schema
// Corverxis Technologies
// SOC 2 Type II compliant data model with full audit trail

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(VIEWER)
  orgId         String?
  org           Org?      @relation(fields: [orgId], references: [id])

  // Auth
  accounts   Account[]
  sessions   Session[]
  apiKeys    ApiKey[]

  // Activity
  sensorSessions SensorSession[]
  auditLogs      AuditLog[]
  alerts         Alert[]

  // Compliance
  consentGivenAt  DateTime?
  dataRegion      String    @default("us-east-1")
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  failedLoginCount Int      @default(0)
  lockedUntil     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete for GDPR right-to-erasure

  @@index([email])
  @@index([orgId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ENGINEER
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Organisation ──────────────────────────────────────────────────────────

model Org {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(STARTER)
  dataRegion  String   @default("us-east-1")
  ssoEnabled  Boolean  @default(false)
  ssoProvider String?
  ssoConfig   Json?

  users        User[]
  assets       Asset[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  complianceDocs ComplianceDoc[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orgs")
}

enum OrgPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── API Keys ──────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique // bcrypt hash — never store plaintext
  prefix      String    // first 8 chars for identification: "sm_live_"
  userId      String
  orgId       String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org         Org?      @relation(fields: [orgId], references: [id])
  scopes      String[]  @default(["predict:read"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

// ─── Assets & Sensors ──────────────────────────────────────────────────────

model Asset {
  id          String      @id @default(cuid())
  name        String
  description String?
  orgId       String
  org         Org         @relation(fields: [orgId], references: [id])
  vertical    String      // manufacturing, aerospace, ev_battery, etc.
  location    String?
  tags        String[]    @default([])

  sensors  Sensor[]
  sessions SensorSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("assets")
}

model Sensor {
  id          String     @id @default(cuid())
  name        String
  type        String     // bearing_temp, spindle_vib, cell_voltage, etc.
  unit        String     // degC, mm/s, V, A, bar, Hz
  assetId     String
  asset       Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  config      Json       @default("{}")
  thresholds  Json       @default("{}") // {warning: 75, critical: 90, low: 10}
  mlAlgorithm String     @default("ensemble")

  readings     SensorReading[]
  predictions  Prediction[]
  alerts       Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@map("sensors")
}

// ─── Time-Series Data ──────────────────────────────────────────────────────

model SensorReading {
  id        String   @id @default(cuid())
  sensorId  String
  sensor    Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  value     Float
  quality   Float    @default(1.0) // 0-1 data quality score
  timestamp DateTime @default(now())

  @@index([sensorId, timestamp])
  @@map("sensor_readings")
}

model Prediction {
  id          String   @id @default(cuid())
  sensorId    String
  sensor      Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  algorithm   String   // ekf, lstm, arima, fourier, ensemble
  predicted   Float
  confidence  Float    // 0-1
  rulHours    Float?   // remaining useful life in hours
  features    Json     @default("{}") // extracted signal features
  timestamp   DateTime @default(now())

  @@index([sensorId, timestamp])
  @@map("predictions")
}

model SensorSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  config     Json     @default("{}")
  ipAddress  String?

  @@index([userId])
  @@index([assetId])
  @@map("sensor_sessions")
}

// ─── Alerts ────────────────────────────────────────────────────────────────

model Alert {
  id         String      @id @default(cuid())
  sensorId   String
  sensor     Sensor      @relation(fields: [sensorId], references: [id])
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  severity   AlertLevel
  type       String      // threshold_breach, rul_critical, anomaly_detected
  message    String
  value      Float?
  threshold  Float?
  resolved   Boolean     @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime    @default(now())

  @@index([sensorId])
  @@index([resolved])
  @@map("alerts")
}

enum AlertLevel {
  INFO
  WARNING
  CRITICAL
}

// ─── Compliance & Audit ────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  orgId       String?
  org         Org?     @relation(fields: [orgId], references: [id])
  action      String   // user.login, sensor.read, api_key.create, data.export
  resource    String?
  resourceId  String?
  ipAddress   String?
  userAgent   String?
  outcome     String   @default("success") // success | failure | blocked
  metadata    Json     @default("{}")
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([timestamp])
  @@map("audit_logs")
}

model ComplianceDoc {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  type      String   // gdpr_consent, ccpa_opt_out, data_processing_agreement
  version   String
  signedAt  DateTime
  signedBy  String
  content   String   @db.Text
  hash      String   // SHA-256 of content for tamper detection

  createdAt DateTime @default(now())

  @@map("compliance_docs")
}

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  dataType        String   @unique // sensor_readings, predictions, audit_logs
  retentionDays   Int
  archiveAfterDays Int?
  deleteAfterDays  Int?
  lastRunAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("data_retention_policies")
}
